---
import { getEntry } from "astro:content";
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";

type Id = CollectionEntry<"news">["id"];
interface Props {
  id: Id;
}
const { id }: Props = Astro.props;
const article = await getEntry("news", id);
const { Content } = await render(article!);
---

{
  article && (
    <article id={id}>
      <header>
        <h1>{article.data.description}</h1>
        <h2>{article.data.date}</h2>
      </header>
      <main>
        <Content />
      </main>
    </article>
  )
}

<style>
  article {
    --news-content-width: min(100%, 72rem);
    --news-narrow-width: min(100%, 56rem);
    --news-surface-color: #fff1ff;
    --news-surface-alt-color: #ffdcff;
    --news-accent-color: #ffdaf4;
    --news-accent-strong-color: #ffa0d8;
    text-align: center;
    padding: 1rem 0 1.5rem;
    display: grid;
    gap: 1.25rem;

    header {
      display: block;
      margin: 0 auto;
      background-color: var(--news-accent-color);
      font-family: "JK Gothic", sans-serif;
      width: min(100%, 40rem);
      text-align: center;
      padding: clamp(0.75rem, 2vw, 1.25rem);
      border-radius: 0.75rem;
      box-sizing: border-box;

      h1 {
        margin: 0;
        font-size: clamp(1.25rem, 2vw + 0.9rem, 2rem);
        line-height: 1.4;
      }
      h2 {
        margin: 0.5rem 0 0;
        font-size: clamp(0.9rem, 0.8rem + 0.25vw, 1rem);
        line-height: 1.4;
      }
    }
  }

  main {
    width: var(--news-content-width);
    margin: 0 auto;
    padding: 0 var(--page-gutter);
    box-sizing: border-box;
    overflow-wrap: anywhere;

    :global(> *:not(img):not(blockquote):not(.astro-code):not(table):not(hr)) {
      width: var(--news-narrow-width);
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      box-sizing: border-box;
      text-align: left;
      line-height: 1.8;
    }

    :global(p),
    :global(ul),
    :global(ol) {
      padding-inline: clamp(0rem, 2vw, 0.25rem);
    }

    :global(ul),
    :global(ol) {
      padding-left: clamp(1.25rem, 3vw, 2rem);
    }

    img {
      max-width: min(100%, 90vw);
      max-height: 90vh;
      width: auto;
      height: auto;
      object-fit: contain;
      display: block;
      margin: 0 auto;
    }

    blockquote {
      margin: 0 auto;
      padding: 0.75rem 1rem;
      width: var(--news-narrow-width);
      max-width: 100%;
      box-sizing: border-box;
      border-radius: 0.5em;
      background-color: var(--news-surface-color);
      text-align: left;
    }

    code {
      background-color: var(--news-surface-color);
      border-radius: 0.25em;
      overflow-wrap: anywhere;
    }

    .astro-code {
      margin: 0 auto;
      padding: 0.75rem;
      width: var(--news-narrow-width);
      max-width: 100%;
      box-sizing: border-box;
      border-radius: 0.5em;
      text-align: left;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;

      pre {
        margin: 0;
        min-width: max-content;
      }

      code {
        background-color: #24292e;
        border-radius: 0;
      }
    }

    table {
      margin: 0 auto;
      display: block;
      width: fit-content;
      max-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      border-spacing: 0;
      border-radius: 0.5em;
      border-collapse: separate;

      thead {
        th {
          padding: 0.6em;
          background-color: var(--news-accent-strong-color);
          white-space: nowrap;
        }
        tr:first-child th:first-child {
          border-top-left-radius: 0.5em;
        }
        tr:first-child th:last-child {
          border-top-right-radius: 0.5em;
        }
      }
      tbody {
        tr:nth-child(odd) td {
          background-color: var(--news-surface-color);
        }
        tr:nth-child(even) td {
          background-color: var(--news-surface-alt-color);
        }
        td {
          padding: 0.6em;
          white-space: nowrap;
        }
        tr:last-child td:first-child {
          border-bottom-left-radius: 0.5em;
        }
        tr:last-child td:last-child {
          border-bottom-right-radius: 0.5em;
        }
      }
    }

    hr {
      margin: 1.25rem auto;
      width: min(80%, 40rem);
      height: 0;
      padding: 0;
      border: 0;
      border-top: 6px dotted #ff6bc2;
    }
  }

  @media screen and (max-width: 768px) {
    article {
      gap: 1rem;
    }

    main {
      padding: 0 0.75rem;
    }
  }
</style>
