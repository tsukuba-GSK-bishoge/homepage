---
const { description, id } = Astro.props;
---

<article>
  <div id="text-wrapper">
    <h2>{description}</h2>
    <section>
      <a href={"/news/" + id}>&gt;&gt; Read more...</a>
    </section>
  </div>
</article>

<style>
  article {
    margin: 1rem auto;
    padding: 1rem;
    background-color: #fff5fb;
    border-radius: 0.75rem;
    width: min(100%, 48rem);
    display: block;
    box-sizing: border-box;

    #text-wrapper {
      padding: clamp(0.5rem, 2vw, 1.5rem);

      h2 {
        text-align: center;
        margin: 0;
        font-size: clamp(1.05rem, 0.95rem + 0.5vw, 1.4rem);
        line-height: 1.6;
      }

      section {
        position: relative;
        transition: 0.25s all;
        width: fit-content;
        margin: 1rem auto 0;
        a {
          text-decoration: none;
        }
      }

      section:hover {
        transform: scale(1.1);
      }
    }
  }
</style>
