---
import type { ImageMetadata } from "astro";

const { id, title, description, keyVisualPath } = Astro.props;
import { Image } from "astro:assets";
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/works/*/keyvisual.{jpeg,jpg,png,gif,webp}");
if (!images[keyVisualPath])
  throw new Error(`"${keyVisualPath}" does not exist in glob: "/src/assets/works/*/keyvisual.{jpeg,jpg,png,gif,webp}"`);
---

<article>
  <header>
    <h1>{title}</h1>
  </header>
  <main>
    <div id="image-wrapper">
      <Image src={images[keyVisualPath]()} alt="Key Visual" class="key-visual" />
    </div>
    <div id="text-wrapper">
      <p>{description}</p>
      <section>
        <a href={"/works/" + id}>&gt;&gt; Read more...</a>
      </section>
    </div>
  </main>
</article>

<style>
  /*
  article {
    margin: 1em;
    padding: 1em;
    background-color: #fff5fb;
    border-radius: 0.5em;
    width: auto;
  }
  */

  article {
    text-align: center;
    padding: 1em 0;

    header {
      display: block;
      margin: 0 auto;
      background-color: #ffdaf4;
      font-family: "JK Gothic", sans-serif;
      width: min(100%, 40rem);
      text-align: center;
      padding: 0.75rem 1rem;
      border-radius: 0.75rem;
      box-sizing: border-box;

      h1 {
        margin: 0;
        font-size: clamp(1.15rem, 0.95rem + 0.6vw, 1.6rem);
        line-height: 1.4;
      }
    }
  }

  main {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;

    #text-wrapper {
      width: min(100%, 48rem);
      padding: 0 1rem 1.5rem;
      box-sizing: border-box;

      h2 {
        text-align: center;
      }

      section {
        position: relative;
        transition: 0.25s all;
        width: fit-content;
        a {
          text-decoration: none;
        }
      }

      section:hover {
        transform: scale(1.1);
      }
    }

    #image-wrapper {
      width: min(100%, 56rem);
      padding: 1rem;
      box-sizing: border-box;
      .key-visual {
        display: block;
        width: auto;
        height: auto;
        max-width: min(100%, 48rem);
        max-height: 80vh;
        margin: 0 auto;
      }
    }
  }
</style>
